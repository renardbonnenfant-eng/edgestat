# === EdgeStat backend ===
# Clé API-Football. Reste UNIQUEMENT côté serveur, jamais exposée au frontend.
# Obtenir une clé gratuite : https://www.api-football.com/ (tier gratuit = 100 req/jour)
API_FOOTBALL_KEY=

# Hôte de l'API. Par défaut : accès direct api-sports.io (header x-apisports-key).
# Si tu utilises l'offre via RapidAPI, change l'hôte et adapte les headers dans apiFootball.js.
API_FOOTBALL_HOST=v3.football.api-sports.io

# Port du serveur backend
PORT=3001

# Garde-fou : nombre max d'appels réels à l'API par jour (le tier gratuit en autorise 100).
# Au-delà, le serveur sert le cache (même périmé) plutôt que de risquer un dépassement.
DAILY_REQUEST_LIMIT=90

# Clé Groq (gratuit) pour le chatbot IA — https://console.groq.com/
GROQ_KEY=
